extends layout

block content
  header.content-header
    .header-text
      h1 RoePilot Dashboard
      p.subtitle University IT Support Center
    a.btn-primary(href="/supportrequests/new")
      i(data-feather="plus") 
      span New Request

  .metrics-row
    .metric-card
      .metric-label TOTAL REQUESTS
      .metric-value #{stats.totalRequests}
    .metric-card
      .metric-label RESOLVED
      .metric-value #{stats.resolved}

  .dashboard-content
    .activity-feed
      h2.section-title Recent Activity
      .feed-list
        if recentActivity && recentActivity.length > 0
          each item in recentActivity
            .feed-card
              .status-bar(class=(item.IsResolved ? 'status-green' : 'status-red'))
              .feed-card-content
                h3 #{item.Title}
                .feed-meta
                  span #{item.Username}
                  span.dot •
                  span #{new Date(item.PostDate).toLocaleDateString()}
        else
          p No recent activity.

    aside.top-contributors
      h2.section-title Top Contributors
      .contributor-list
        if topContributors && topContributors.length > 0
          each user in topContributors
            .contributor-item
              .contributor-icon
                i(data-feather="user")
              .contributor-info
                .contributor-name #{user.Username}
                .contributor-rep #{user.CredibilityScore} rep
        else
          p No contributors found.