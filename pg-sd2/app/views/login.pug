extends layout

block content
  .auth-wrapper
    .auth-card
      .auth-logo
        img(src="/images/R.png", alt="RoePilot Logo")
      h1 Welcome back
      p.subtitle Sign in to continue managing support requests and answers.

      if error
        .alert.alert-error #{error}

      form.auth-form(action="/login", method="POST")
        .form-group
          label.field-label(for="identifier") Username or Email
          input#identifier(type="text", name="identifier", placeholder="Enter your username or email", required)
        .form-group
          label.field-label(for="password") Password
          input#password(type="password", name="password", placeholder="Enter your password", required)
        button.btn-primary(type="submit")
          i(data-feather="log-in")
          span Sign In

      p.auth-link
        | Don’t have an account?
        a(href="/register") Create one now