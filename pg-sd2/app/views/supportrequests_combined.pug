extends layout

block content
  header.content-header
    .header-text
      if pageTitle
        h1 #{pageTitle}
      else if filterUserName
        h1 Support Requests by #{filterUserName}
      else
        h1 Support Requests

  section.panel
    form.search-form#searchForm(method="get", action="/supportrequests")
      if filterUserId
        input(type="hidden", name="user", value=filterUserId)
      if filterCategoryId
        input(type="hidden", name="category", value=filterCategoryId)
      input#searchInput(type="text", name="search", placeholder="Search requests...", value=(search || ""))
      button.btn-primary(type="submit") Search

  if hasActiveFilter
    a.btn-link(href="/supportrequests") ← Back to all requests

  if error
    .alert.alert-error #{error}
  else if posts && posts.length
    .request-list
      each post in posts
        article.request-card
          .request-header
            .status-bar(class=(post.IsResolved ? 'status-green' : 'status-red'))
            div.request-title-wrap
              a.request-title(href="/supportrequests?category=" + post.CategoryID)
                h3 #{post.Title}
              .feed-meta
                span Opened by #{post.Username}
                span •
                span #{new Date(post.PostDate).toLocaleDateString()}
                span •
                span Category: #{post.CategoryName}
                if post.BountyValue > 0
                  span •
                  span.badge.badge-warning Bounty #{post.BountyValue} rep

          if post.tags && post.tags.length > 0
            .tag-list
              each tag in post.tags
                span.tag-chip #{tag}

          .post-body
            p #{post.Description}

          if post.answers.length
            .answers-header
              h3 #{post.answers.length} Answers
            .answers-list
              each answer in post.answers
                article.answer-card(class=(answer.IsAccepted ? "accepted" : ""))
                  .vote-col
                    form(action="/answers/upvote/" + answer.AnswerID, method="post")
                      button.icon-btn(type="submit", aria-label="Upvote answer")
                        i(data-feather="chevron-up")
                    div.vote-value #{answer.NumOfUpvote}
                    form(action="/answers/downvote/" + answer.AnswerID, method="post")
                      button.icon-btn(type="submit", aria-label="Downvote answer")
                        i(data-feather="chevron-down")
                    if answer.IsAccepted
                      i.accepted-icon(data-feather="check-circle")

                  .answer-content-col
                    p #{answer.AnswerText}
                    .feed-meta
                      if answer.IsAccepted
                        span.badge.badge-success Accepted Answer
                        span •
                      span by @#{answer.AnswerAuthor}
                      span •
                      span Answered on #{new Date(answer.PostDate).toLocaleDateString()}

                    if user && !answer.IsAccepted && Number(post.UserID) === Number(user.id)
                      form(action="/answers/accept/" + answer.AnswerID, method="post")
                        button.btn-secondary(type="submit") Mark as Accepted

          if user
            .add-answer
              h3 Your Answer
              form.auth-form(method="POST", action="/answers/" + post.RequestID)
                textarea(name="answerText", placeholder="Write a clear, actionable answer..." required rows="5")
                .form-actions
                  button.btn-primary(type="submit") Post Answer

  else
    .empty-state No support requests available.

  script.
    liveFilter("searchInput", "request-card");
