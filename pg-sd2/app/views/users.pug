extends layout

block content
  header.content-header
    .header-text
      h1 Users
      p.subtitle Browse the university support network and discover top contributors.

  section.panel
    form.search-form#searchForm(method="get", action="/users")
      input#searchInput(type="text", name="search", placeholder="Search users...", value=(search || ""))
      button.btn-primary(type="submit") Search

  if error
    .alert.alert-error #{error}
  else if users && users.length
    .user-grid
      each user in users
        article.user-card
          .user-card-header
            img.profile-img(src=(user.ProfilePic ? "/images/" + user.ProfilePic : "https://ui-avatars.com/api/?name=" + user.Username + "&background=000&color=fff"), alt="Profile Picture")
            div
              h3 #{user.Username}
              p.user-role University Member

          .user-card-stats
            .stat-box
              p.stat-label Reputation
              p.stat-value #{user.CredibilityScore || 0}
            .stat-box
              p.stat-label University ID
              p.stat-value #{user.UniversityID}

          a.btn-secondary(href="/users/" + user.UserID) View Profile
  else
    .empty-state No users available.

  script.
    liveFilter("searchInput", "user-card");
