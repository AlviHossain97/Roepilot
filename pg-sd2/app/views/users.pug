extends layout

block content
  header.content-header(style="margin-bottom: 32px;")
    .header-text
      h1 Users
      p.subtitle Browse people in the university network

  .search-wrapper(style="margin-bottom: 48px;")
    form#searchForm(method="get", action="/users", style="display: flex; gap: 16px;")
      input#searchInput(type="text", name="search", placeholder="Search users...", value=(search || ""))
      button.btn-primary(type="submit") Search

  if error
    p.error(style="color: var(--accent-alert);") #{error}
  else if users && users.length
    .user-grid
      each user in users
        .user-card
          .user-card-header
            img.profile-img(src=(user.ProfilePic ? "/images/" + user.ProfilePic : "https://ui-avatars.com/api/?name=" + user.Username + "&background=000&color=fff"), alt="Profile Picture")
            div
              h2 #{user.Username}
              p.user-role University Member
              
          .user-card-stats
            .stat-box
              p.stat-label REP
              p.stat-value #{user.CredibilityScore}
            .stat-box
              p.stat-label ID
              p.stat-value #{user.UniversityID}
              
          a.btn-primary(href="/users/" + user.UserID style="width: 100%; justify-content: center; margin-top: auto;") View Profile
  else
    p No users available.

  script.
    liveFilter("searchInput", "user-card");
