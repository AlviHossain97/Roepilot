extends layout

block content
  header.content-header
    .header-text
      h1 #{isSelf ? "My Profile" : profileUser.Username + "'s Profile"}
      p.subtitle Member since #{new Date(profileUser.RegistrationDate).toLocaleDateString()}

  section.profile-hero.panel
    .profile-head
      if profileUser.ProfilePic
        img.profile-avatar(src=`/images/${profileUser.ProfilePic}`, alt="Profile Picture")
      else
        img.profile-avatar(src=`https://ui-avatars.com/api/?name=${profileUser.Username}&background=111827&color=ffffff`, alt="Default Picture")
      .profile-meta
        h2 #{profileUser.Username}
        p.user-role University Member
        p.subtitle #{profileUser.Email}

    .stat-strip
      .stat-box
        p.stat-label Reputation
        p.stat-value #{profileUser.CredibilityScore || 0}
      .stat-box
        p.stat-label University ID
        p.stat-value #{profileUser.UniversityID}
      .stat-box
        p.stat-label Requests
        p.stat-value #{supportRequests.length}
      .stat-box
        p.stat-label Answers
        p.stat-value #{userAnswers.length}

    if isSelf
      a.btn-secondary(href="/profile/edit")
        i(data-feather="edit-2")
        span Edit Profile

  .profile-grid
    section.panel
      .panel-header
        h2.section-title Support Requests
      if supportRequests.length
        .stack-list
          each req in supportRequests
            article.list-item
              h3= req.Title
              p= req.Description
              p.muted-text Posted on #{new Date(req.PostDate).toLocaleDateString()}
      else
        p.empty-state This user hasn’t made any support requests yet.

    section.panel
      .panel-header
        h2.section-title Answers
      if userAnswers.length
        .stack-list
          each ans in userAnswers
            article.list-item
              h3 Answer to: #{ans.RequestTitle}
              p= ans.AnswerText
              p.muted-text Posted on #{new Date(ans.PostDate).toLocaleDateString()}
      else
        p.empty-state No answers yet.
