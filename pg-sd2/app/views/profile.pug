extends layout

block content
  header.content-header(style="margin-bottom: 32px;")
    .header-text
      h1 #{isSelf ? "My Profile" : profileUser.Username + "'s Profile"}
      p.subtitle Member since #{new Date(profileUser.RegistrationDate).toLocaleDateString()}

  .user-card(style="max-width: 600px; margin-bottom: 48px;")
    .user-card-header
      if profileUser.ProfilePic
        img.profile-img(src=`/images/${profileUser.ProfilePic}`, alt="Profile Picture")
      else
        img.profile-img(src=`https://ui-avatars.com/api/?name=${profileUser.Username}&background=000&color=fff`, alt="Default Picture")
      div
        h2 #{profileUser.Username}
        p.user-role University Member

    .user-card-stats
      .stat-box
        p.stat-label REP
        p.stat-value #{profileUser.CredibilityScore || 0}
      .stat-box
        p.stat-label ID
        p.stat-value #{profileUser.UniversityID}
      .stat-box
        p.stat-label EMAIL
        p.stat-value(style="font-size: 14px; margin-top: auto;") #{profileUser.Email}

    if isSelf
      a.btn-primary(href="/profile/edit" style="justify-content: center;") Edit Profile

    hr

    h2 Support Requests
    if supportRequests.length
      each req in supportRequests
        .post-box
          h3= req.Title
          p= req.Description
          p.small Posted on #{req.PostDate}
    else
      p This user hasn’t made any support requests yet.

    hr

    h2 Answers
    if userAnswers.length
      each ans in userAnswers
        .answer-box
          h4 Answer to: #{ans.RequestTitle}
          p= ans.AnswerText
          p.small Posted on #{ans.PostDate}
    else
      p No answers yet.
