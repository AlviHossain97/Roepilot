extends layout

block content
  header.content-header
    .header-text
      h1 Support Categories
      p.subtitle Explore request domains and jump into relevant discussions.

  section.panel
    form.search-form#searchForm(method="get", action="/categories")
      input#searchInput(type="text", name="search", placeholder="Search categories...", value=(search || ""))
      button.btn-primary(type="submit") Search

  if error
    .alert.alert-error #{error}
  else if categories && categories.length
    .category-grid
      each category in categories
        article.category-card
          .category-header
            h3 #{category.CategoryName}
            img.category-img(
              src=(category.Image ? "/images/categories/" + category.Image : "/images/default-category.png"),
              alt=category.CategoryName
            )
          p #{category.Description}
          a.btn-secondary(href="/supportrequests?category=" + category.CategoryID) View Requests
  else
    .empty-state No categories available.

  script.
    liveFilter("searchInput", "category-card");
