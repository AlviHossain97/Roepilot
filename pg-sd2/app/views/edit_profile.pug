extends layout

block content
  section.panel.form-panel
    h1 Edit Profile
    p.subtitle Update your contact details and profile picture.

    form.auth-form(method="POST", action="/profile/edit", enctype="multipart/form-data")
      input(type="hidden", name="_csrf", value=csrfToken)
      .form-group
        label.field-label(for="email") Email
        input#email(type="email", name="email", value=profileUser.Email, required)

      .form-group
        label.field-label(for="universityId") University ID
        input#universityId(type="text", name="universityId", value=profileUser.UniversityID)

      .form-group
        label.field-label(for="profilePic") Profile Picture
        if profileUser.ProfilePic
          img.profile-avatar(src=`/images/${profileUser.ProfilePic}`, alt="Current Profile Picture")
        else
          img.profile-avatar(src=`https://ui-avatars.com/api/?name=${profileUser.Username || 'User'}&background=111827&color=ffffff`, alt="Default Picture")
        input#profilePic(type="file", name="profilePic", accept="image/*")

      .form-actions
        button.btn-primary(type="submit")
          i(data-feather="save")
          span Save Changes
        a.btn-secondary(href="/profile") Cancel
