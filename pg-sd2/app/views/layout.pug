doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title #{pageTitle ? pageTitle + " · RoePilot" : "RoePilot"}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600&family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet", href="/styles.css")
    script(src="https://unpkg.com/feather-icons")
    style.
      mark.highlight { background-color: #fde047; color: #1e293b; padding: 0 2px; border-radius: 3px; }
    script.
      function highlightText(element, keyword) {
        if (!keyword) return;
        const regex = new RegExp(`(${keyword})`, "gi");
        const content = element.innerHTML.replace(/<mark class="highlight">|<\/mark>/g, "");
        element.innerHTML = content.replace(regex, '<mark class="highlight">$1</mark>');
      }
      function liveFilter(inputId, itemClass) {
        const input = document.getElementById(inputId);
        if (!input) return;
        input.addEventListener('input', () => {
          const value = input.value.trim().toLowerCase();
          const items = document.querySelectorAll(`.${itemClass}`);
          items.forEach(item => {
            const text = item.innerText.toLowerCase();
            const match = text.includes(value);
            item.style.display = match ? '' : 'none';
            const textElements = item.querySelectorAll("h2, h3, p");
            textElements.forEach(el => highlightText(el, value));
          });
        });
      }
  body
    if user
      .app-container
        aside.sidebar
          a.brand-link(href="/home")
            .logo-box
              i(data-feather="life-buoy")
            .brand-copy
              strong RoePilot
              span Support Hub

          nav.sidebar-nav
            a(href="/home", class=(activePage === 'home' ? 'active' : ''))
              i(data-feather="home")
              span.sidebar-label Dashboard
            a(href="/supportrequests", class=(activePage === 'requests' ? 'active' : ''))
              i(data-feather="file-text")
              span.sidebar-label Requests
            a(href="/categories", class=(activePage === 'categories' ? 'active' : ''))
              i(data-feather="grid")
              span.sidebar-label Categories
            a(href="/users", class=(activePage === 'users' ? 'active' : ''))
              i(data-feather="users")
              span.sidebar-label Users
            a(href="/profile", class=(activePage === 'profile' ? 'active' : ''))
              i(data-feather="user")
              span.sidebar-label Profile

          .sidebar-bottom
            form.sidebar-logout-form(action="/logout", method="POST")
              input(type="hidden", name="_csrf", value=csrfToken)
              button.sidebar-logout-btn(type="submit")
                i(data-feather="log-out")
                span.sidebar-label Logout

        .main-shell
          header.topbar
            .topbar-title
              h2 #{pageTitle || "RoePilot"}
              p.topbar-subtitle Collaborative IT help across the Roehampton community
            .topbar-actions
              a.btn-secondary.topbar-action(href="/supportrequests/new")
                i(data-feather="plus-circle")
                span New Request
              a.user-chip(href="/profile")
                i(data-feather="user")
                span @#{user.username}

          main.main-content
            block content
    else
      .auth-layout
        block content

    script.
      feather.replace();
