extends layout

block content
  .auth-wrapper
    .auth-card
      .auth-logo
        img(src="/images/R.png", alt="RoePilot Logo")
      h1 Register
      p.subtitle(style="margin-bottom: 32px;") Create an account for RoePilot IT Support

      if error
        p.error(style="color: var(--accent-alert); margin-bottom: 16px;") #{error}
      if success
        p.success(style="color: var(--accent-success); margin-bottom: 16px;") #{success}

      form(action="/register", method="POST", style="display: flex; flex-direction: column; gap: 16px;")
        div
          label(style="font-family: var(--font-data); font-size: 12px; color: var(--text-muted);") Username
          input(type="text", name="username", placeholder="Choose a username", required, style="margin-top: 8px;")
        div
          label(style="font-family: var(--font-data); font-size: 12px; color: var(--text-muted);") Email Address
          input(type="email", name="email", placeholder="Enter your email", required, style="margin-top: 8px;")
        div
          label(style="font-family: var(--font-data); font-size: 12px; color: var(--text-muted);") University ID
          input(type="text", name="universityId", placeholder="e.g. U1234567", required, style="margin-top: 8px;")
        div
          label(style="font-family: var(--font-data); font-size: 12px; color: var(--text-muted);") Password
          input(type="password", name="password", placeholder="Create a password", required, style="margin-top: 8px;")
        
        button.btn-primary(type="submit" style="width: 100%; justify-content: center; padding: 14px; margin-top: 16px; font-size: 14px;") Create Account

      p.auth-link(style="margin-top: 32px; text-align: center; font-family: var(--font-data); font-size: 13px;")
        | Already have an account? 
        a(href="/login" style="color: var(--accent-primary); font-weight: 500; text-decoration: none;") Log in here