extends layout

block content
  .auth-wrapper
    .auth-card
      .auth-logo
        img(src="/images/R.png", alt="RoePilot Logo")
      h1 Create account
      p.subtitle Join RoePilot to ask questions, share answers, and grow your credibility.

      if error
        .alert.alert-error #{error}
      if success
        .alert.alert-success #{success}

      form.auth-form(action="/register", method="POST")
        input(type="hidden", name="_csrf", value=csrfToken)
        .form-group
          label.field-label(for="username") Username
          input#username(type="text", name="username", placeholder="Choose a username", required)
        .form-group
          label.field-label(for="email") Email Address
          input#email(type="email", name="email", placeholder="Enter your email", required)
        .form-group
          label.field-label(for="universityId") University ID
          input#universityId(type="text", name="universityId", placeholder="e.g. U1234567", required)
        .form-group
          label.field-label(for="password") Password
          input#password(type="password", name="password", placeholder="Create a password", required)

        button.btn-primary(type="submit")
          i(data-feather="user-plus")
          span Create Account

      p.auth-link
        | Already have an account?
        a(href="/login") Sign in instead
